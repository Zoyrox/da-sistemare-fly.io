<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Ricerca Avanzata - MotoStaffa Office</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/img/logo.svg">
</head>
<body>
  <div class="app-container">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <div class="logo">
          <div class="logo-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          </div>
          <div class="logo-text">
            <h1>MotoStaffa</h1>
            <span>Office</span>
          </div>
        </div>
      </div>

      <nav class="sidebar-nav">
        <a href="/" class="nav-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
          Dashboard
        </a>
        <a href="/orders/new" class="nav-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12h8"/><path d="M12 8v8"/></svg>
          Nuovo Ordine
        </a>
        <a href="/search" class="nav-item active">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          Ricerca Avanzata
        </a>
        <a href="/labels/queue" class="nav-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect width="12" height="8" x="6" y="14"/></svg>
          Coda Etichette
        </a>
        <a href="/stats" class="nav-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
          Statistiche
        </a>
        <div class="sidebar-divider"></div>
        <a href="/api/export" class="nav-item" download>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Esporta Dati
        </a>
      </nav>

      <div class="sidebar-footer">
        <div class="user-info">
          <div class="user-avatar">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <div class="user-details">
            <div class="name"><%= user.username %></div>
            <div class="role">Amministratore</div>
          </div>
        </div>
        <form action="/logout" method="POST">
          <button type="submit" class="btn btn-secondary" style="width: 100%;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Logout
          </button>
        </form>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
      <header class="header">
        <div class="header-left">
          <button class="menu-toggle" id="menuToggle">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
          </button>
          <div class="page-title">
            <h2>Ricerca Avanzata</h2>
            <p>Cerca in tutti i campi degli ordini</p>
          </div>
        </div>
      </header>

      <div class="content">
        <!-- Search Box -->
        <div class="card" style="margin-bottom: 24px;">
          <div class="card-body">
            <div class="search-box-large">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
              <input type="text" id="searchInput" value="<%= query %>" placeholder="Cerca per ID, Nome, Telefono, Città, Provincia, Paese, Tracking..." autocomplete="off">
            </div>
            <div class="search-filters-tags" style="margin-top: 16px;">
              <span class="filter-tag info">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                La ricerca include: ID ordine, numero ordine, nome cliente, telefono, email, città, provincia, CAP, paese, codice tracking
              </span>
            </div>
          </div>
        </div>

        <!-- Results -->
        <div class="card">
          <div class="card-header">
            <h3 class="card-title">Risultati</h3>
            <span id="resultsCount" style="font-size: 13px; color: var(--text-muted);">0 ordini trovati</span>
          </div>
          <div class="table-container">
            <table class="table" id="resultsTable">
              <thead>
                <tr>
                  <th>N° Ordine</th>
                  <th>Cliente</th>
                  <th>Contatti</th>
                  <th>Indirizzo</th>
                  <th>Prodotto</th>
                  <th>Stato</th>
                  <th>Azioni</th>
                </tr>
              </thead>
              <tbody id="resultsBody">
                <!-- Results will be loaded here -->
              </tbody>
            </table>
          </div>
          
          <div id="emptyState" class="empty-state" style="display: none;">
            <div class="empty-state-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </div>
            <h3>Nessun risultato</h3>
            <p>Prova a cercare con termini diversi</p>
          </div>
          
          <div id="initialState" class="empty-state">
            <div class="empty-state-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </div>
            <h3>Inizia a cercare</h3>
            <p>Inserisci un termine per cercare tra gli ordini</p>
          </div>
        </div>
      </div>
    </main>
  </div>

  <div class="toast-container" id="toastContainer"></div>

  <script>
    // Mobile menu
    document.getElementById('menuToggle').addEventListener('click', () => {
      document.getElementById('sidebar').classList.toggle('open');
    });

    const searchInput = document.getElementById('searchInput');
    const resultsBody = document.getElementById('resultsBody');
    const resultsCount = document.getElementById('resultsCount');
    const emptyState = document.getElementById('emptyState');
    const initialState = document.getElementById('initialState');
    let searchTimeout;

    searchInput.addEventListener('input', (e) => {
      clearTimeout(searchTimeout);
      const query = e.target.value.trim();
      
      if (query.length === 0) {
        resultsBody.innerHTML = '';
        resultsCount.textContent = '0 ordini trovati';
        emptyState.style.display = 'none';
        initialState.style.display = 'block';
        return;
      }
      
      initialState.style.display = 'none';
      searchTimeout = setTimeout(() => performSearch(query), 300);
    });

    async function performSearch(query) {
      try {
        const res = await fetch(`/api/orders/search?q=${encodeURIComponent(query)}`);
        const data = await res.json();
        renderResults(data.orders);
      } catch (err) {
        showToast('Errore durante la ricerca', 'error');
      }
    }

    function renderResults(orders) {
      resultsCount.textContent = `${orders.length} ordine${orders.length !== 1 ? 'i' : ''} trovato${orders.length !== 1 ? 'i' : ''}`;
      
      if (orders.length === 0) {
        resultsBody.innerHTML = '';
        emptyState.style.display = 'block';
        return;
      }
      
      emptyState.style.display = 'none';
      
      const badges = { 
        pending: 'badge-pending', 
        processing: 'badge-processing', 
        shipped: 'badge-shipped', 
        delivered: 'badge-delivered', 
        cancelled: 'badge-cancelled' 
      };
      const labels = { 
        pending: 'In Attesa', 
        processing: 'In Lavorazione', 
        shipped: 'Spedito', 
        delivered: 'Consegnato', 
        cancelled: 'Annullato' 
      };
      
      resultsBody.innerHTML = orders.map(order => `
        <tr onclick="window.location.href='/orders/${order.id}'" style="cursor: pointer;">
          <td>
            <span class="order-number">${order.order_display_number || '#' + order.id}</span>
            ${order.is_urgent ? '<span class="urgent-badge">!</span>' : ''}
          </td>
          <td>
            <div style="font-weight: 500;">${order.customer_name}</div>
          </td>
          <td>
            <div style="font-size: 13px;">${order.customer_phone || '-'}</div>
            ${order.customer_email ? `<div style="font-size: 12px; color: var(--text-muted);">${order.customer_email}</div>` : ''}
          </td>
          <td>
            <div style="font-size: 13px;">${order.customer_address || '-'}</div>
            <div style="font-size: 12px; color: var(--text-muted);">
              ${order.customer_zip || ''} ${order.customer_city || ''}
              ${order.customer_province ? '(' + order.customer_province + ')' : ''}
              ${order.customer_country && order.customer_country !== 'Italia' ? '• ' + order.customer_country : ''}
            </div>
          </td>
          <td>
            <div style="font-weight: 500;">${order.product_model}</div>
            <div style="font-size: 12px; color: var(--text-muted);">Qty: ${order.quantity} • €${Number(order.price_total).toFixed(2)}</div>
          </td>
          <td>
            <span class="badge ${badges[order.status]}">${labels[order.status]}</span>
          </td>
          <td>
            <div class="action-buttons">
              <a href="/orders/${order.id}" class="btn btn-sm btn-secondary btn-icon" onclick="event.stopPropagation()" title="Visualizza">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
              </a>
              <a href="/orders/${order.id}/edit" class="btn btn-sm btn-secondary btn-icon" onclick="event.stopPropagation()" title="Modifica">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg>
              </a>
            </div>
          </td>
        </tr>
      `).join('');
    }

    // Toast
    function showToast(msg, type) {
      const container = document.getElementById('toastContainer');
      const toast = document.createElement('div');
      toast.className = `toast toast-${type}`;
      toast.textContent = msg;
      container.appendChild(toast);
      setTimeout(() => toast.remove(), 3000);
    }

    // Focus on search input
    document.addEventListener('DOMContentLoaded', () => {
      searchInput.focus();
      if (searchInput.value.length >= 1) {
        performSearch(searchInput.value);
      }
    });
  </script>
</body>
</html>
