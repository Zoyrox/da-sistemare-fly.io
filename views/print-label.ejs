<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Etichette - MotoStaffa Spedizioni</title>
  <link rel="icon" type="image/svg+xml" href="/img/logo.svg">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    
    body { 
      font-family: 'Arial', 'Helvetica', sans-serif; 
      background: #f0f0f0; 
      padding: 20px;
      line-height: 1.4;
    }
    
    .labels-wrapper {
      max-width: 900px;
      margin: 0 auto;
    }
    
    .labels-title {
      text-align: center;
      margin-bottom: 20px;
      color: #333;
    }
    
    .labels-title h1 {
      font-size: 24px;
      margin-bottom: 8px;
    }
    
    .labels-title p {
      font-size: 14px;
      color: #666;
    }
    
    .labels-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
      gap: 20px;
      margin-bottom: 20px;
    }
    
    .label-pair {
      display: flex;
      flex-direction: row;
      gap: 15px;
      flex-wrap: wrap;
      justify-content: center;
    }
    
    .label {
      background: white;
      border: 2px solid #333;
      border-radius: 12px;
      padding: 20px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    
    .label-type {
      font-size: 10px;
      text-transform: uppercase;
      color: #fff;
      letter-spacing: 1.5px;
      margin-bottom: 12px;
      padding: 5px 10px;
      border-radius: 4px;
      display: inline-block;
      font-weight: bold;
    }
    
    .label-type.dest {
      background: #2563eb;
    }
    
    .label-type.mitt {
      background: #dc2626;
    }
    
    .recipient-name {
      font-size: 20px;
      font-weight: bold;
      color: #000;
      margin-bottom: 10px;
      text-transform: uppercase;
      line-height: 1.3;
    }
    
    .recipient-address {
      font-size: 14px;
      color: #333;
      line-height: 1.4;
      margin-bottom: 3px;
    }
    
    .recipient-zip-city {
      font-size: 14px;
      font-weight: 600;
      color: #000;
      margin-top: 6px;
    }
    
    .recipient-province {
      font-size: 14px;
      font-weight: 600;
      color: #000;
      margin-top: 2px;
    }
    
    .recipient-country {
      font-size: 13px;
      font-weight: bold;
      color: #dc2626;
      margin-top: 6px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    
    .recipient-country.italy {
      color: #2563eb;
    }
    
    .recipient-country.international {
      color: #dc2626;
      font-size: 14px;
    }
    
    .print-btn {
      display: block;
      width: 100%;
      max-width: 900px;
      margin: 20px auto;
      padding: 16px;
      background: #f97316;
      color: white;
      border: none;
      border-radius: 12px;
      font-size: 16px;
      font-weight: bold;
      cursor: pointer;
      transition: background 0.2s;
    }
    
    .print-btn:hover {
      background: #ea580c;
    }
    
    .copy-section {
      max-width: 900px;
      margin: 20px auto;
      background: white;
      border-radius: 12px;
      padding: 20px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    
    .copy-section h3 {
      font-size: 16px;
      margin-bottom: 16px;
      color: #333;
    }
    
    .copy-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 16px;
    }
    
    .copy-box {
      background: #f8f8f8;
      padding: 12px;
      border-radius: 8px;
    }
    
    .copy-box h4 {
      font-size: 12px;
      color: #666;
      margin-bottom: 8px;
      text-transform: uppercase;
    }
    
    .copy-box textarea {
      width: 100%;
      padding: 10px;
      border: 1px solid #ddd;
      border-radius: 6px;
      font-family: 'Courier New', monospace;
      font-size: 12px;
      resize: vertical;
      min-height: 80px;
      background: white;
    }
    
    .copy-btn {
      margin-top: 8px;
      padding: 8px 12px;
      background: #333;
      color: white;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-size: 12px;
      transition: background 0.2s;
    }
    
    .copy-btn:hover {
      background: #555;
    }
    
    .order-separator {
      grid-column: 1 / -1;
      height: 2px;
      background: linear-gradient(to right, transparent, #ddd, transparent);
      margin: 10px 0;
    }
    
    @media print {
      body { 
        background: white; 
        padding: 0; 
        margin: 0; 
      }
      
      .no-print { 
        display: none !important; 
      }
      
      .labels-wrapper { 
        max-width: 100%; 
      }
      
      .labels-title {
        display: none;
      }
      
      .labels-grid { 
        display: block;
      }
      
      .label-pair {
        page-break-inside: avoid;
        margin-bottom: 15mm;
        gap: 10mm;
      }
      
      .label { 
        border: 1px solid #000; 
        border-radius: 0;
        box-shadow: none;
        width: 90mm;
        max-width: 90mm;
        padding: 15px;
        page-break-inside: avoid;
      }
      
      .order-separator {
        page-break-after: always;
        display: none;
      }
      
      @page { 
        size: A4; 
        margin: 10mm;
      }
    }
    
    @media (max-width: 768px) {
      .labels-grid {
        grid-template-columns: 1fr;
      }
      
      .label-pair {
        flex-direction: column;
      }
      
      .copy-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <button class="print-btn no-print" onclick="window.print()">🖨️ Stampa Etichette (<%= orders.length %>)</button>

  <div class="labels-wrapper">
    <div class="labels-title no-print">
      <h1>Etichette di Spedizione</h1>
      <p><%= orders.length %> ordine<%= orders.length !== 1 ? 'i' : '' %> da stampare</p>
    </div>

    <div class="labels-grid">
      <% orders.forEach((order, index) => { %>
        <div class="label-pair">
          <!-- Etichetta Destinatario -->
          <div class="label">
            <div class="label-type dest">DESTINATARIO</div>
            <div class="recipient-name"><%= order.customer_name %></div>
            <% if (order.customer_address) { %>
              <div class="recipient-address"><%= order.customer_address %></div>
            <% } %>
            <div class="recipient-zip-city">
              <%= order.customer_zip || '' %> <%= order.customer_city || '' %>
              <% if (order.customer_province) { %>(<%= order.customer_province.toUpperCase() %>)<% } %>
            </div>
            <div class="recipient-country <%= (!order.customer_country || order.customer_country === 'Italia') ? 'italy' : 'international' %>">
              <%= (order.customer_country || 'Italia').toUpperCase() %>
            </div>
          </div>

          <!-- Etichetta Mittente -->
          <div class="label">
            <div class="label-type mitt">MITTENTE</div>
            <div class="recipient-name">Mauro Masucci</div>
            <div class="recipient-address">Via Strada di Spina, 2</div>
            <div class="recipient-zip-city">20054 Segrate (MI)</div>
            <div class="recipient-country italy">ITALIA</div>
          </div>
        </div>
        
        <% if (index < orders.length - 1) { %>
          <div class="order-separator no-print"></div>
        <% } %>
      <% }) %>
    </div>
  </div>

  <div class="copy-section no-print">
    <h3>📋 Copia Indirizzi</h3>
    <div class="copy-grid">
      <% orders.forEach(order => { %>
        <div class="copy-box">
          <h4><%= order.order_display_number || '#' + order.id %> - <%= order.customer_name %></h4>
          <textarea readonly>Dest: <%= order.customer_name %>
<%= order.customer_address %>
<%= order.customer_zip %> <%= order.customer_city %><% if (order.customer_province) { %> (<%= order.customer_province.toUpperCase() %>)<% } %>
<%= order.customer_country || 'Italia' %></textarea>
          <button class="copy-btn" onclick="copyToClipboard(this)">Copia</button>
        </div>
      <% }) %>
    </div>
  </div>

  <script>
    function copyToClipboard(btn) {
      const textarea = btn.previousElementSibling;
      textarea.select();
      textarea.setSelectionRange(0, 99999);
      try {
        document.execCommand('copy');
        const originalText = btn.textContent;
        btn.textContent = '✓ Copiato!';
        btn.style.background = '#22c55e';
        setTimeout(() => {
          btn.textContent = originalText;
          btn.style.background = '#333';
        }, 2000);
      } catch (err) {
        console.error('Errore copia: ', err);
        alert('Premi Ctrl+C per copiare');
      }
    }
    
    // Auto-print if single order
    <% if (orders.length === 1 && singleMode) { %>
    // window.print();
    <% } %>
  </script>
</body>
</html>
