<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Dashboard - MotoStaffa Office</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/img/logo.svg">
</head>
<body>
  <div class="app-container">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <div class="logo">
          <div class="logo-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          </div>
          <div class="logo-text">
            <h1>MotoStaffa</h1>
            <span>Office</span>
          </div>
        </div>
      </div>

      <nav class="sidebar-nav">
        <a href="/" class="nav-item active">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
          Dashboard
        </a>
        <a href="/orders/new" class="nav-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12h8"/><path d="M12 8v8"/></svg>
          Nuovo Ordine
        </a>
        <a href="/search" class="nav-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          Ricerca Avanzata
        </a>
        <a href="/labels/queue" class="nav-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect width="12" height="8" x="6" y="14"/></svg>
          Coda Etichette
          <% if (labelQueueCount > 0) { %>
            <span class="nav-badge"><%= labelQueueCount %></span>
          <% } %>
        </a>
        <a href="/stats" class="nav-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
          Statistiche
        </a>
        <div class="sidebar-divider"></div>
        <a href="/api/export" class="nav-item" download>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Esporta Dati
        </a>
      </nav>

      <div class="sidebar-footer">
        <div class="user-info">
          <div class="user-avatar">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <div class="user-details">
            <div class="name"><%= user.username %></div>
            <div class="role">Amministratore</div>
          </div>
        </div>
        <form action="/logout" method="POST">
          <button type="submit" class="btn btn-secondary" style="width: 100%;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Logout
          </button>
        </form>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
      <!-- Header -->
      <header class="header">
        <div class="header-left">
          <button class="menu-toggle" id="menuToggle">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
          </button>
          <div class="page-title">
            <h2>Dashboard</h2>
            <p><%= new Date().toLocaleDateString('it-IT', { weekday: 'long', day: 'numeric', month: 'long' }) %></p>
          </div>
        </div>
        <div class="header-actions">
          <a href="/search" class="btn btn-secondary btn-icon" title="Ricerca Avanzata">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </a>
          <a href="/orders/new" class="btn btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
            Nuovo Ordine
          </a>
        </div>
      </header>

      <!-- Content -->
      <div class="content">
        <!-- Search Bar -->
        <div class="card search-card" style="margin-bottom: 20px;">
          <div class="card-body">
            <div class="search-box-large">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
              <input type="text" id="globalSearch" placeholder="Cerca per ID, Nome, Città, Provincia, Paese..." autocomplete="off">
            </div>
            <div class="search-tags">
              <span class="search-tag">ID: #123</span>
              <span class="search-tag">Nome: Mario</span>
              <span class="search-tag">Città: Roma</span>
              <span class="search-tag">Provincia: RM</span>
              <span class="search-tag">Paese: Italia</span>
            </div>
            <div id="searchResults" class="search-results-dropdown" style="display: none;"></div>
          </div>
        </div>

        <!-- Stats -->
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-header">
              <span class="stat-label">Ordini Oggi</span>
              <div class="stat-icon blue">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
              </div>
            </div>
            <div class="stat-value"><%= stats.today.count %></div>
            <div class="stat-subtitle">€<%= Number(stats.today.revenue || 0).toFixed(2) %> fatturato</div>
          </div>

          <div class="stat-card">
            <div class="stat-header">
              <span class="stat-label">Da Spedire</span>
              <div class="stat-icon yellow">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
              </div>
            </div>
            <div class="stat-value"><%= stats.toShip.count %></div>
            <div class="stat-subtitle">in attesa</div>
          </div>

          <div class="stat-card">
            <div class="stat-header">
              <span class="stat-label">In Transito</span>
              <div class="stat-icon green">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 17h4V5H2v12h3"/><path d="M20 17h2v-3.34a4 4 0 0 0-1.17-2.83L19 9h-5"/><path d="M14 17h1"/><circle cx="7.5" cy="17.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>
              </div>
            </div>
            <div class="stat-value"><%= stats.inTransit.count %></div>
            <div class="stat-subtitle">spedizioni</div>
          </div>

          <div class="stat-card">
            <div class="stat-header">
              <span class="stat-label">Fatturato Mese</span>
              <div class="stat-icon orange">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
              </div>
            </div>
            <div class="stat-value">€<%= Number(stats.monthlyRevenue?.total || 0).toFixed(0) %></div>
            <div class="stat-subtitle">questo mese</div>
          </div>

          <div class="stat-card">
            <div class="stat-header">
              <span class="stat-label">Staffa Carbonio</span>
              <div class="stat-icon" style="background: rgba(99, 102, 241, 0.15); color: #6366f1;">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/></svg>
              </div>
            </div>
            <div class="stat-value"><%= stats.carbonio?.count || 0 %></div>
            <div class="stat-subtitle">ordini totali</div>
          </div>

          <div class="stat-card">
            <div class="stat-header">
              <span class="stat-label">Staffa Alluminio</span>
              <div class="stat-icon" style="background: rgba(168, 85, 247, 0.15); color: #a855f7;">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/></svg>
              </div>
            </div>
            <div class="stat-value"><%= stats.alluminio?.count || 0 %></div>
            <div class="stat-subtitle">ordini totali</div>
          </div>

          <div class="stat-card">
            <div class="stat-header">
              <span class="stat-label">Ritiro Subito</span>
              <div class="stat-icon" style="background: rgba(34, 197, 94, 0.15); color: #22c55e;">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m4.93 4.93 14.14 14.14"/></svg>
              </div>
            </div>
            <div class="stat-value"><%= stats.subitoPickup?.count || 0 %></div>
            <div class="stat-subtitle">in sede</div>
          </div>

          <div class="stat-card">
            <div class="stat-header">
              <span class="stat-label">Internazionali</span>
              <div class="stat-icon" style="background: rgba(6, 182, 212, 0.15); color: #06b6d4;">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              </div>
            </div>
            <div class="stat-value"><%= stats.international?.count || 0 %></div>
            <div class="stat-subtitle">spedizioni estere</div>
          </div>
        </div>

        <!-- Alerts -->
        <% if (alerts && alerts.length > 0) { %>
          <div class="alert alert-warning" style="margin-bottom: 20px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            <div>
              <strong>Attenzione:</strong> <%= alerts.length %> ordini spediti da piu di 7 giorni non ancora segnati come consegnati
            </div>
          </div>
        <% } %>

        <!-- Label Queue Alert -->
        <% if (labelQueueCount > 0) { %>
          <div class="alert alert-info" style="margin-bottom: 20px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect width="12" height="8" x="6" y="14"/></svg>
            <div>
              <strong>Hai <%= labelQueueCount %> ordini</strong> in coda per la stampa etichette. 
              <a href="/labels/print" target="_blank" style="color: inherit; text-decoration: underline;">Stampa ora</a>
            </div>
          </div>
        <% } %>

        <!-- Filters -->
        <div class="card" style="margin-bottom: 20px;">
          <div class="card-header">
            <h3 class="card-title">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
              Filtri
            </h3>
          </div>
          <div class="card-body">
            <div class="form-row filters-row">
              <div class="form-group">
                <label class="form-label">Tipo Staffa</label>
                <select id="filterModel" class="form-select" onchange="applyFilters()">
                  <option value="all">Tutte</option>
                  <option value="carbonio">Carbonio</option>
                  <option value="alluminio">Alluminio</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Stato</label>
                <select id="filterStatus" class="form-select" onchange="applyFilters()">
                  <option value="all">Tutti</option>
                  <option value="pending">In Attesa</option>
                  <option value="processing">In Lavorazione</option>
                  <option value="shipped">Spedito</option>
                  <option value="delivered">Consegnato</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Fonte</label>
                <select id="filterSource" class="form-select" onchange="applyFilters()">
                  <option value="all">Tutte</option>
                  <option value="facebook">Facebook</option>
                  <option value="subito">Subito.it</option>
                  <option value="whatsapp">WhatsApp</option>
                  <option value="direct">Diretto</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Ordina per</label>
                <select id="filterSort" class="form-select" onchange="applyFilters()">
                  <option value="created">Data creazione</option>
                  <option value="sale_date">Data vendita</option>
                  <option value="display_number">Numero ordine</option>
                </select>
              </div>
              <div class="form-group filter-actions">
                <button class="btn btn-secondary" onclick="resetFilters()">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 12"/></svg>
                  Reset
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Orders Table -->
        <div class="card">
          <div class="card-header">
            <h3 class="card-title">Ordini Recenti</h3>
            <span style="font-size: 13px; color: var(--text-muted);"><span id="orderCount"><%= recentOrders.length %></span> ordini</span>
          </div>
          <div class="table-container">
            <table class="table">
              <thead>
                <tr>
                  <th class="col-id">N°</th>
                  <th class="col-cliente">Cliente</th>
                  <th class="col-prodotto">Prodotto</th>
                  <th class="col-prezzo">Prezzo</th>
                  <th class="col-stato">Stato</th>
                  <th class="col-azioni">Azioni</th>
                </tr>
              </thead>
              <tbody id="ordersTableBody">
                <% recentOrders.forEach(order => { %>
                  <tr data-order-id="<%= order.id %>">
                    <td class="col-id">
                      <span class="order-number"><%= order.order_display_number || '#' + order.id %></span>
                      <% if (order.is_urgent) { %>
                        <span class="urgent-badge">!</span>
                      <% } %>
                    </td>
                    <td class="col-cliente">
                      <div class="cliente-nome"><%= order.customer_name %></div>
                      <div class="cliente-luogo">
                        <%= order.customer_city %>
                        <% if (order.customer_country && order.customer_country !== 'Italia') { %>
                          <span class="country-badge"><%= order.customer_country %></span>
                        <% } %>
                      </div>
                    </td>
                    <td class="col-prodotto">
                      <div class="prodotto-nome"><%= order.product_model %></div>
                      <div class="prodotto-qty">Qty: <%= order.quantity %></div>
                    </td>
                    <td class="col-prezzo">€<%= Number(order.price_total).toFixed(2) %></td>
                    <td class="col-stato">
                      <% const badges = { 
                        pending: 'badge-pending', 
                        processing: 'badge-processing', 
                        shipped: 'badge-shipped', 
                        delivered: 'badge-delivered', 
                        cancelled: 'badge-cancelled' 
                      }; %>
                      <% const labels = { 
                        pending: 'In Attesa', 
                        processing: 'In Lavorazione', 
                        shipped: 'Spedito', 
                        delivered: 'Consegnato', 
                        cancelled: 'Annullato' 
                      }; %>
                      <span class="badge <%= badges[order.status] %>"><%= labels[order.status] %></span>
                    </td>
                    <td class="col-azioni">
                      <div class="action-buttons">
                        <button class="btn btn-sm btn-secondary btn-icon" onclick="event.stopPropagation(); toggleLabelQueue('<%= order.id %>', this)" title="Aggiungi/Rimuovi da etichette">
                          <svg class="label-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect width="12" height="8" x="6" y="14"/></svg>
                        </button>
                        <button class="btn btn-sm btn-secondary btn-icon" onclick="event.stopPropagation(); duplicateOrder('<%= order.id %>')" title="Duplica ordine">
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                        </button>
                        <button class="btn btn-sm btn-secondary btn-icon" onclick="event.stopPropagation(); updateStatus('<%= order.id %>', 'processing')" title="In lavorazione">
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                        </button>
                        <button class="btn btn-sm btn-secondary btn-icon" onclick="event.stopPropagation(); updateStatus('<%= order.id %>', 'shipped')" title="Spedito">
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 17h4V5H2v12h3"/><path d="M20 17h2v-3.34a4 4 0 0 0-1.17-2.83L19 9h-5"/><path d="M14 17h1"/><circle cx="7.5" cy="17.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>
                        </button>
                        <a href="/orders/<%= order.id %>/edit" class="btn btn-sm btn-secondary btn-icon" onclick="event.stopPropagation()" title="Modifica">
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg>
                        </a>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          
          <% if (recentOrders.length === 0) { %>
            <div class="empty-state">
              <div class="empty-state-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              </div>
              <h3>Nessun ordine trovato</h3>
              <a href="/orders/new">Crea il primo ordine</a>
            </div>
          <% } %>
        </div>
      </div>
    </main>
  </div>

  <div class="toast-container" id="toastContainer"></div>

  <script>
    // Mobile menu
    document.getElementById('menuToggle').addEventListener('click', () => {
      document.getElementById('sidebar').classList.toggle('open');
    });

    // Close sidebar when clicking outside on mobile
    document.addEventListener('click', (e) => {
      const sidebar = document.getElementById('sidebar');
      const menuToggle = document.getElementById('menuToggle');
      if (window.innerWidth <= 1024 && sidebar.classList.contains('open')) {
        if (!sidebar.contains(e.target) && !menuToggle.contains(e.target)) {
          sidebar.classList.remove('open');
        }
      }
    });

    // Update status
    async function updateStatus(id, status) {
      try {
        const res = await fetch(`/api/orders/${id}/status`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status })
        });
        if (res.ok) {
          showToast('Stato aggiornato!', 'success');
          setTimeout(() => location.reload(), 500);
        }
      } catch (err) {
        showToast('Errore', 'error');
      }
    }

    // Duplicate order
    async function duplicateOrder(id) {
      try {
        const res = await fetch(`/api/orders/${id}/duplicate`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        });
        if (res.ok) {
          const data = await res.json();
          showToast('Ordine duplicato!', 'success');
          setTimeout(() => location.reload(), 500);
        } else {
          showToast('Errore durante la duplicazione', 'error');
        }
      } catch (err) {
        showToast('Errore', 'error');
      }
    }

    // Toggle label queue
    async function toggleLabelQueue(orderId, btn) {
      try {
        const res = await fetch(`/api/label-queue/${orderId}/check`);
        const { inQueue } = await res.json();
        
        if (inQueue) {
          await fetch(`/api/label-queue/${orderId}`, { method: 'DELETE' });
          btn.classList.remove('active');
          showToast('Rimosso dalla coda etichette', 'success');
        } else {
          await fetch(`/api/label-queue/${orderId}`, { method: 'POST' });
          btn.classList.add('active');
          showToast('Aggiunto alla coda etichette', 'success');
        }
      } catch (err) {
        showToast('Errore', 'error');
      }
    }

    // Global search
    const searchInput = document.getElementById('globalSearch');
    const searchResults = document.getElementById('searchResults');
    let searchTimeout;

    searchInput.addEventListener('input', (e) => {
      clearTimeout(searchTimeout);
      const query = e.target.value.trim();
      
      if (query.length === 0) {
        searchResults.style.display = 'none';
        return;
      }
      
      searchTimeout = setTimeout(() => performSearch(query), 300);
    });

    async function performSearch(query) {
      try {
        const res = await fetch(`/api/orders/search?q=${encodeURIComponent(query)}`);
        const data = await res.json();
        renderSearchResults(data.orders);
      } catch (err) {
        console.error('Search error:', err);
      }
    }

    function renderSearchResults(orders) {
      if (orders.length === 0) {
        searchResults.innerHTML = '<div class="search-no-results">Nessun risultato trovato</div>';
      } else {
        searchResults.innerHTML = orders.map(order => `
          <a href="/orders/${order.id}" class="search-result-item">
            <div class="search-result-main">
              <span class="search-result-number">${order.order_display_number || '#' + order.id}</span>
              <span class="search-result-name">${order.customer_name}</span>
            </div>
            <div class="search-result-meta">
              ${order.customer_city || ''} 
              ${order.customer_province ? '(' + order.customer_province + ')' : ''}
              ${order.customer_country && order.customer_country !== 'Italia' ? '• ' + order.customer_country : ''}
            </div>
          </a>
        `).join('');
      }
      searchResults.style.display = 'block';
    }

    // Hide search results when clicking outside
    document.addEventListener('click', (e) => {
      if (!e.target.closest('.search-card')) {
        searchResults.style.display = 'none';
      }
    });

    // Filters
    let allOrders = <%- JSON.stringify(recentOrders) %>;
    
    function applyFilters() {
      const modelFilter = document.getElementById('filterModel').value;
      const statusFilter = document.getElementById('filterStatus').value;
      const sourceFilter = document.getElementById('filterSource').value;
      const sortBy = document.getElementById('filterSort').value;
      
      let filtered = [...allOrders];
      
      if (modelFilter !== 'all') {
        filtered = filtered.filter(o => o.product_model.toLowerCase().includes(modelFilter));
      }
      
      if (statusFilter !== 'all') {
        filtered = filtered.filter(o => o.status === statusFilter);
      }
      
      if (sourceFilter !== 'all') {
        filtered = filtered.filter(o => o.source === sourceFilter);
      }
      
      // Sorting
      if (sortBy === 'sale_date') {
        filtered.sort((a, b) => new Date(b.sale_date || b.created_at) - new Date(a.sale_date || a.created_at));
      } else if (sortBy === 'display_number') {
        filtered.sort((a, b) => {
          const numA = parseInt((a.order_display_number || '#' + a.id).replace('#', ''));
          const numB = parseInt((b.order_display_number || '#' + b.id).replace('#', ''));
          return numA - numB;
        });
      }
      
      renderOrders(filtered);
    }
    
    function resetFilters() {
      document.getElementById('filterModel').value = 'all';
      document.getElementById('filterStatus').value = 'all';
      document.getElementById('filterSource').value = 'all';
      document.getElementById('filterSort').value = 'created';
      renderOrders(allOrders);
    }
    
    function renderOrders(orders) {
      const tbody = document.getElementById('ordersTableBody');
      document.getElementById('orderCount').textContent = orders.length;
      
      if (orders.length === 0) {
        tbody.innerHTML = `
          <tr>
            <td colspan="6" style="text-align: center; padding: 40px;">
              <div class="empty-state">
                <div class="empty-state-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                </div>
                <h3>Nessun ordine trovato</h3>
              </div>
            </td>
          </tr>
        `;
        return;
      }
      
      const badges = { 
        pending: 'badge-pending', 
        processing: 'badge-processing', 
        shipped: 'badge-shipped', 
        delivered: 'badge-delivered', 
        cancelled: 'badge-cancelled' 
      };
      const labels = { 
        pending: 'In Attesa', 
        processing: 'In Lavorazione', 
        shipped: 'Spedito', 
        delivered: 'Consegnato', 
        cancelled: 'Annullato' 
      };
      
      tbody.innerHTML = orders.map(order => `
        <tr data-order-id="${order.id}" onclick="window.location.href='/orders/${order.id}'">
          <td class="col-id">
            <span class="order-number">${order.order_display_number || '#' + order.id}</span>
            ${order.is_urgent ? '<span class="urgent-badge">!</span>' : ''}
          </td>
          <td class="col-cliente">
            <div class="cliente-nome">${order.customer_name}</div>
            <div class="cliente-luogo">
              ${order.customer_city || 'N/D'}
              ${order.customer_country && order.customer_country !== 'Italia' ? '<span class="country-badge">' + order.customer_country + '</span>' : ''}
            </div>
          </td>
          <td class="col-prodotto">
            <div class="prodotto-nome">${order.product_model}</div>
            <div class="prodotto-qty">Qty: ${order.quantity}</div>
          </td>
          <td class="col-prezzo">€${Number(order.price_total).toFixed(2)}</td>
          <td class="col-stato">
            <span class="badge ${badges[order.status]}">${labels[order.status]}</span>
          </td>
          <td class="col-azioni">
            <div class="action-buttons">
              <button class="btn btn-sm btn-secondary btn-icon" onclick="event.stopPropagation(); toggleLabelQueue('${order.id}', this)" title="Aggiungi/Rimuovi da etichette">
                <svg class="label-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect width="12" height="8" x="6" y="14"/></svg>
              </button>
              <button class="btn btn-sm btn-secondary btn-icon" onclick="event.stopPropagation(); updateStatus('${order.id}', 'processing')" title="In lavorazione">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              </button>
              <button class="btn btn-sm btn-secondary btn-icon" onclick="event.stopPropagation(); updateStatus('${order.id}', 'shipped')" title="Spedito">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 17h4V5H2v12h3"/><path d="M20 17h2v-3.34a4 4 0 0 0-1.17-2.83L19 9h-5"/><path d="M14 17h1"/><circle cx="7.5" cy="17.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>
              </button>
              <a href="/orders/${order.id}/edit" class="btn btn-sm btn-secondary btn-icon" onclick="event.stopPropagation()" title="Modifica">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg>
              </a>
            </div>
          </td>
        </tr>
      `).join('');
    }

    // Toast
    function showToast(msg, type) {
      const container = document.getElementById('toastContainer');
      const toast = document.createElement('div');
      toast.className = `toast toast-${type}`;
      toast.textContent = msg;
      container.appendChild(toast);
      setTimeout(() => toast.remove(), 3000);
    }

    // Check label queue status for visible orders
    async function checkLabelQueueStatus() {
      const rows = document.querySelectorAll('#ordersTableBody tr[data-order-id]');
      for (const row of rows) {
        const orderId = row.dataset.orderId;
        const btn = row.querySelector('.label-icon').parentElement;
        try {
          const res = await fetch(`/api/label-queue/${orderId}/check`);
          const { inQueue } = await res.json();
          if (inQueue) btn.classList.add('active');
        } catch (err) {}
      }
    }
    
    // Initialize
    document.addEventListener('DOMContentLoaded', () => {
      checkLabelQueueStatus();
    });
  </script>
</body>
</html>
