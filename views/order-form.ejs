<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= mode === 'create' ? 'Nuovo Ordine' : 'Modifica Ordine' %> - MotoStaffa Office</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/img/logo.svg">
</head>
<body>
  <div class="app-container">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <div class="logo">
          <div class="logo-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          </div>
          <div class="logo-text">
            <h1>MotoStaffa</h1>
            <span>Office</span>
          </div>
        </div>
      </div>

      <nav class="sidebar-nav">
        <a href="/" class="nav-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
          Dashboard
        </a>
        <a href="/orders/new" class="nav-item active">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12h8"/><path d="M12 8v8"/></svg>
          Nuovo Ordine
        </a>
        <a href="/search" class="nav-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          Ricerca Avanzata
        </a>
        <a href="/labels/queue" class="nav-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect width="12" height="8" x="6" y="14"/></svg>
          Coda Etichette
        </a>
        <a href="/stats" class="nav-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
          Statistiche
        </a>
        <div class="sidebar-divider"></div>
        <a href="/api/export" class="nav-item" download>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Esporta Dati
        </a>
      </nav>

      <div class="sidebar-footer">
        <div class="user-info">
          <div class="user-avatar">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <div class="user-details">
            <div class="name"><%= user.username %></div>
            <div class="role">Amministratore</div>
          </div>
        </div>
        <form action="/logout" method="POST">
          <button type="submit" class="btn btn-secondary" style="width: 100%;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Logout
          </button>
        </form>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
      <header class="header">
        <div class="header-left">
          <button class="menu-toggle" id="menuToggle">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
          </button>
          <div class="page-title">
            <h2><%= mode === 'create' ? 'Nuovo Ordine' : 'Modifica Ordine ' + (order?.order_display_number || '#' + order?.id) %></h2>
          </div>
        </div>
        <% if (mode === 'edit') { %>
          <button class="btn btn-danger" onclick="deleteOrder('<%= order.id %>')">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
            Elimina
          </button>
        <% } %>
      </header>

      <div class="content">
        <!-- Smart Paste (solo creazione) -->
        <% if (mode === 'create') { %>
          <div class="card" style="margin-bottom: 24px;">
            <div class="card-header">
              <h3 class="card-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 8px;"><path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72Z"/><path d="m14 7 3 3"/></svg>
                Incolla da Messenger/WhatsApp
              </h3>
            </div>
            <div class="card-body">
              <div class="smart-paste">
                <textarea id="smartPaste" placeholder="Incolla qui il messaggio del cliente con nome, telefono, indirizzo... L'AI riconoscerà automaticamente anche il tipo di staffa (carbonio/alluminio), la quantità, il prezzo e il paese!"></textarea>
              </div>
              <div class="smart-paste-actions">
                <button type="button" class="btn btn-primary" id="btnEstrai" onclick="parseSmartPaste()">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72Z"/><path d="m14 7 3 3"/></svg>
                  Estrai Dati con AI
                </button>
                <button type="button" class="btn btn-secondary" onclick="document.getElementById('smartPaste').value=''">
                  Cancella
                </button>
              </div>
              <div class="ai-features" style="margin-top: 16px; padding: 12px; background: var(--bg-input); border-radius: 8px;">
                <div style="font-size: 12px; color: var(--text-muted); margin-bottom: 8px;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 4px;"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                  L'AI riconosce automaticamente:
                </div>
                <div class="ai-features-list">
                  <span class="ai-feature">Nome & Telefono</span>
                  <span class="ai-feature">Indirizzo completo</span>
                  <span class="ai-feature">Tipo staffa (Carbonio/Alluminio)</span>
                  <span class="ai-feature">Quantità & Prezzo</span>
                  <span class="ai-feature">Paese (anche estero)</span>
                </div>
              </div>
            </div>
          </div>
        <% } %>

        <!-- Form -->
        <form class="card" id="orderForm">
          <!-- Numero Ordine (solo modifica) -->
          <% if (mode === 'edit') { %>
            <div class="form-section">
              <h3 class="form-section-title">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"/></svg>
                Numero Ordine
              </h3>
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label">Numero Visualizzato</label>
                  <div style="display: flex; gap: 10px;">
                    <input type="text" id="displayNumber" class="form-input" value="<%= order?.order_display_number || '#' + order?.id %>" placeholder="#1">
                    <button type="button" class="btn btn-secondary" onclick="updateDisplayNumber()">Aggiorna</button>
                  </div>
                  <small style="color: var(--text-muted); font-size: 12px;">Modifica il numero visualizzato senza cambiare l'ID interno</small>
                </div>
                <div class="form-group">
                  <label class="form-label">ID Interno</label>
                  <input type="text" class="form-input" value="<%= order?.id %>" readonly style="background: var(--bg-input); color: var(--text-muted);">
                </div>
              </div>
            </div>
          <% } %>

          <!-- Cliente -->
          <div class="form-section">
            <h3 class="form-section-title">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              Dati Cliente
            </h3>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Nome e Cognome <span class="required">*</span></label>
                <input type="text" name="customer_name" class="form-input" value="<%= order?.customer_name || '' %>" required>
              </div>
              <div class="form-group">
                <label class="form-label">Telefono</label>
                <input type="tel" name="customer_phone" class="form-input" value="<%= order?.customer_phone || '' %>">
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">Email</label>
              <input type="email" name="customer_email" class="form-input" value="<%= order?.customer_email || '' %>">
            </div>
          </div>

          <!-- Subito.it Options - sempre visibile per tutte le fonti -->
          <div class="form-section" id="subitoSection">
            <h3 class="form-section-title">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m4.93 4.93 14.14 14.14"/></svg>
              Opzioni Gestione Ordine
            </h3>
            
            <!-- Opzione ritiro in sede -->
            <div class="form-check" style="margin-bottom: 16px;">
              <input type="checkbox" name="is_subito_pickup" id="isSubitoPickup" class="form-check-input" value="true" <%= order?.is_subito_pickup ? 'checked' : '' %> onchange="toggleSubitoPickup()">
              <label for="isSubitoPickup" class="form-check-label">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 4px; color: var(--primary);"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                <strong>Ritiro in sede</strong> - Il cliente ritira personalmente (nessuna spedizione)
              </label>
            </div>
            
            <!-- Opzioni indirizzo parziale - visibile solo quando NON è ritiro in sede -->
            <div id="subitoAddressOptions" style="display: <%= order?.is_subito_pickup ? 'none' : 'block' %>; margin-top: 16px; padding: 16px; background: var(--bg-secondary); border-radius: 12px;">
              <p style="font-size: 13px; color: var(--text-muted); margin-bottom: 12px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 4px;"><path d="M12 9h.01"/><path d="M11 12h1v4h1"/><circle cx="12" cy="12" r="10"/></svg>
                Seleziona quali dati dell'indirizzo hai disponibili. I campi deselezionati saranno nascosti e non obbligatori.
              </p>
              <div class="form-row" style="grid-template-columns: repeat(2, 1fr); gap: 12px;">
                <div class="form-check">
                  <input type="checkbox" id="includeAddress" class="form-check-input" <%= !order || order?.customer_address ? 'checked' : '' %> onchange="toggleAddressField('customer_address')">
                  <label for="includeAddress" class="form-check-label">Via/Indirizzo</label>
                </div>
                <div class="form-check">
                  <input type="checkbox" id="includeCap" class="form-check-input" <%= !order || order?.customer_zip ? 'checked' : '' %> onchange="toggleAddressField('customer_zip')">
                  <label for="includeCap" class="form-check-label">CAP</label>
                </div>
                <div class="form-check">
                  <input type="checkbox" id="includeCity" class="form-check-input" <%= !order || order?.customer_city ? 'checked' : '' %> onchange="toggleAddressField('customer_city')">
                  <label for="includeCity" class="form-check-label">Città</label>
                </div>
                <div class="form-check">
                  <input type="checkbox" id="includeProvince" class="form-check-input" <%= !order || order?.customer_province ? 'checked' : '' %> onchange="toggleAddressField('customer_province')">
                  <label for="includeProvince" class="form-check-label">Provincia</label>
                </div>
                <div class="form-check">
                  <input type="checkbox" id="includeCountry" class="form-check-input" checked onchange="toggleAddressField('customer_country')">
                  <label for="includeCountry" class="form-check-label">Paese</label>
                </div>
              </div>
            </div>
          </div>

          <!-- Indirizzo -->
          <div class="form-section" id="addressSection">
            <h3 class="form-section-title">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              Indirizzo di Spedizione
            </h3>
            <div class="form-group" id="addressGroup">
              <label class="form-label">Indirizzo <span class="required" id="addressRequired">*</span></label>
              <div style="display: flex; gap: 10px;">
                <input type="text" name="customer_address" id="customer_address" class="form-input" value="<%= order?.customer_address || '' %>">
                <button type="button" class="btn btn-secondary" onclick="verifyAddress()" title="Verifica indirizzo con Google Maps">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                  Verifica
                </button>
              </div>
              <small id="geocodeResult" style="color: var(--text-muted); font-size: 12px; display: none;"></small>
            </div>
            <div class="form-row">
              <div class="form-group" id="zipGroup">
                <label class="form-label">CAP <span class="required" id="zipRequired">*</span></label>
                <input type="text" name="customer_zip" id="customer_zip" class="form-input" value="<%= order?.customer_zip || '' %>" onblur="lookupComune()">
              </div>
              <div class="form-group" id="cityGroup">
                <label class="form-label">Citta <span class="required" id="cityRequired">*</span></label>
                <input type="text" name="customer_city" id="customer_city" class="form-input" value="<%= order?.customer_city || '' %>">
              </div>
              <div class="form-group" id="provinceGroup">
                <label class="form-label">Provincia</label>
                <input type="text" name="customer_province" id="customer_province" class="form-input" value="<%= order?.customer_province || '' %>" maxlength="2" style="text-transform: uppercase;">
              </div>
            </div>
            <div class="form-group">
              <label class="form-label">Paese</label>
              <input type="text" name="customer_country" id="customer_country" class="form-input" value="<%= order?.customer_country || 'Italia (IT)' %>" placeholder="Es: Italia (IT), Stati Uniti (US)">
              <small style="color: var(--text-muted); font-size: 12px;">Formato: Nome Paese (XX) - L'AI lo rileva automaticamente</small>
            </div>
          </div>

          <!-- Prodotto -->
          <div class="form-section">
            <h3 class="form-section-title">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
              Prodotto
            </h3>
            <div class="form-row">
              <div class="form-group" style="flex: 2;">
                <label class="form-label">Modello Staffa <span class="required">*</span></label>
                <select name="product_model" class="form-select" id="productSelect" required>
                  <option value="">Seleziona prodotto</option>
                  <% templates.forEach(t => { %>
                    <option value="<%= t.model %>" data-price="<%= t.default_price %>" <%= order?.product_model === t.model ? 'selected' : '' %>><%= t.name %> - €<%= t.default_price %></option>
                  <% }) %>
                  <option value="custom" <%= order && !templates.find(t => t.model === order.product_model) ? 'selected' : '' %>>Altro (personalizzato)</option>
                </select>
                <input type="text" id="customProduct" class="form-input" style="margin-top: 8px; display: <%= order && !templates.find(t => t.model === order.product_model) ? 'block' : 'none' %>;" placeholder="Specifica il prodotto" value="<%= order && !templates.find(t => t.model === order.product_model) ? order.product_model : '' %>">
              </div>
              <div class="form-group">
                <label class="form-label">Quantita <span class="required">*</span></label>
                <input type="number" name="quantity" class="form-input" value="<%= order?.quantity || 1 %>" min="1" required>
              </div>
              <div class="form-group">
                <label class="form-label">Prezzo (€) <span class="required">*</span></label>
                <input type="number" name="price_total" class="form-input" id="priceInput" value="<%= order?.price_total || '' %>" step="0.01" min="0" required>
              </div>
            </div>
          </div>

          <!-- Stato -->
          <div class="form-section">
            <h3 class="form-section-title">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.1a2 2 0 0 1-1-1.72v-.51a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
              Stato, Data e Tracking
            </h3>
            <div class="form-row">
              <div class="form-group">
                <label class="form-label">Stato</label>
                <select name="status" class="form-select">
                  <option value="pending" <%= order?.status === 'pending' ? 'selected' : '' %>>In Attesa</option>
                  <option value="processing" <%= order?.status === 'processing' ? 'selected' : '' %>>In Lavorazione</option>
                  <option value="shipped" <%= order?.status === 'shipped' ? 'selected' : '' %>>Spedito</option>
                  <option value="delivered" <%= order?.status === 'delivered' ? 'selected' : '' %>>Consegnato</option>
                  <option value="cancelled" <%= order?.status === 'cancelled' ? 'selected' : '' %>>Annullato</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Data Vendita</label>
                <input type="date" name="sale_date" class="form-input" value="<%= order?.sale_date ? new Date(order.sale_date).toISOString().split('T')[0] : new Date().toISOString().split('T')[0] %>">
              </div>
              <div class="form-group">
                <label class="form-label">Fonte</label>
                <select name="source" class="form-select" id="sourceSelect">
                  <option value="facebook" <%= order?.source === 'facebook' ? 'selected' : '' %>>Facebook</option>
                  <option value="subito" <%= order?.source === 'subito' ? 'selected' : '' %>>Subito.it</option>
                  <option value="whatsapp" <%= order?.source === 'whatsapp' ? 'selected' : '' %>>WhatsApp</option>
                  <option value="direct" <%= order?.source === 'direct' ? 'selected' : '' %>>Diretto</option>
                </select>
              </div>
            </div>
            <div class="form-row" style="margin-top: 16px;">
              <div class="form-group">
                <label class="form-label">Codice Tracking</label>
                <input type="text" name="tracking_code" class="form-input" value="<%= order?.tracking_code || '' %>" placeholder="IX123456789IT" style="text-transform: uppercase;">
              </div>
              <% if (order?.order_number) { %>
              <div class="form-group">
                <label class="form-label">Numero Ordine Interno</label>
                <input type="text" class="form-input" value="<%= order.order_number %>" readonly style="background: var(--bg-secondary); font-family: monospace; color: var(--text-muted);">
              </div>
              <% } %>
            </div>
            <div class="form-check" style="margin-top: 16px;">
              <input type="checkbox" name="is_urgent" id="isUrgent" class="form-check-input" value="true" <%= order?.is_urgent ? 'checked' : '' %>>
              <label for="isUrgent" class="form-check-label">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 4px; color: var(--danger);"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                Ordine urgente (spedire entro 24h)
              </label>
            </div>
          </div>

          <!-- Note -->
          <div class="form-section">
            <h3 class="form-section-title">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
              Note e Link
            </h3>
            <div class="form-group">
              <label class="form-label">Link Facebook Messenger</label>
              <input type="url" name="facebook_chat_url" class="form-input" value="<%= order?.facebook_chat_url || '' %>" placeholder="https://facebook.com/...">
            </div>
            <div class="form-group">
              <label class="form-label">Link Annuncio Subito</label>
              <input type="url" name="subito_ad_url" class="form-input" value="<%= order?.subito_ad_url || '' %>" placeholder="https://subito.it/...">
            </div>
            <div class="form-group">
              <label class="form-label">Note Interne</label>
              <textarea name="notes" class="form-textarea" placeholder="Note sul cliente, preferenze, ecc."><%= order?.notes || '' %></textarea>
            </div>
          </div>

          <!-- Actions -->
          <div class="form-section" style="display: flex; gap: 12px; justify-content: flex-end;">
            <a href="/" class="btn btn-secondary">Annulla</a>
            <button type="submit" class="btn btn-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
              <%= mode === 'create' ? 'Crea Ordine' : 'Salva Modifiche' %>
            </button>
          </div>
        </form>
      </div>
    </main>
  </div>

  <div class="toast-container" id="toastContainer"></div>

  <script>
    // Mobile menu
    document.getElementById('menuToggle').addEventListener('click', () => {
      document.getElementById('sidebar').classList.toggle('open');
    });

    // Product select
    document.getElementById('productSelect').addEventListener('change', function() {
      const selected = this.options[this.selectedIndex];
      const customInput = document.getElementById('customProduct');
      const priceInput = document.getElementById('priceInput');
      
      if (this.value === 'custom') {
        customInput.style.display = 'block';
        customInput.required = true;
      } else {
        customInput.style.display = 'none';
        customInput.required = false;
        if (selected.dataset.price) {
          priceInput.value = selected.dataset.price;
        }
      }
    });

    // Toggle Subito Pickup - hide/show address fields
    function toggleSubitoPickup() {
      const isPickup = document.getElementById('isSubitoPickup').checked;
      const addressSection = document.getElementById('addressSection');
      const addressOptions = document.getElementById('subitoAddressOptions');
      
      if (isPickup) {
        // Ritiro in sede: nascondi tutta la sezione indirizzo
        addressSection.style.display = 'none';
        addressOptions.style.display = 'none';
        // Rimuovi required da tutti i campi indirizzo
        document.getElementById('customer_address').required = false;
        document.getElementById('customer_zip').required = false;
        document.getElementById('customer_city').required = false;
        document.getElementById('customer_province').required = false;
      } else {
        // Spedizione normale: mostra sezione indirizzo e opzioni
        addressSection.style.display = 'block';
        addressOptions.style.display = 'block';
        // Aggiorna i campi in base alle checkbox selezionate
        updateAddressRequirements();
      }
    }

    // Toggle individual address fields
    function toggleAddressField(fieldName) {
      const fieldMap = {
        'customer_address': 'includeAddress',
        'customer_zip': 'includeCap',
        'customer_city': 'includeCity',
        'customer_province': 'includeProvince',
        'customer_country': 'includeCountry'
      };
      
      const checkboxId = fieldMap[fieldName];
      const checkbox = document.getElementById(checkboxId);
      const field = document.getElementById(fieldName);
      const requiredSpan = document.getElementById(fieldName.replace('customer_', '') + 'Required');
      
      if (checkbox && checkbox.checked) {
        // Mostra il campo
        field.closest('.form-group, .form-row > div').style.display = 'block';
        field.disabled = false;
        if (requiredSpan) requiredSpan.style.display = 'inline';
        // Rendi obbligatorio solo se è un campo essenziale
        if (fieldName === 'customer_address' || fieldName === 'customer_city') {
          field.required = true;
        }
      } else {
        // Nascondi il campo
        field.closest('.form-group, .form-row > div').style.display = 'none';
        field.disabled = true;
        field.required = false;
        if (requiredSpan) requiredSpan.style.display = 'none';
        // Non svuotare il valore, potrebbe essere utile mantenerlo
      }
    }

    // Update address field requirements based on checkboxes
    function updateAddressRequirements() {
      const fields = ['customer_address', 'customer_zip', 'customer_city', 'customer_province'];
      fields.forEach(field => {
        toggleAddressField(field);
      });
    }

    // Initialize on page load
    document.addEventListener('DOMContentLoaded', function() {
      // Inizializza lo stato dei campi indirizzo
      toggleSubitoPickup();
      // Applica lo stato delle checkbox ai campi
      updateAddressRequirements();
    });

    // Smart Paste Parser con AI avanzata
    async function parseSmartPaste() {
      const text = document.getElementById('smartPaste').value;
      if (!text.trim()) return;

      // Mostra loading
      const btn = document.getElementById('btnEstrai');
      const originalText = btn.innerHTML;
      btn.innerHTML = '<span class="loading-spinner"></span> Analisi AI...';
      btn.disabled = true;

      try {
        const res = await fetch('/api/ai-parse', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ text })
        });

        const data = await res.json();

        if (data.error) {
          showToast('Errore: ' + data.error, 'error');
          return;
        }
        
        // Se non ci sono dati validi, mostra avviso
        if (!data.customer_name && !data.customer_address && !data.product_model) {
          showToast('Nessun dato rilevato. Prova a incollare più informazioni.', 'warning');
          return;
        }

        // Compila i campi cliente
        if (data.customer_name) document.querySelector('input[name="customer_name"]').value = data.customer_name;
        if (data.customer_phone) document.querySelector('input[name="customer_phone"]').value = data.customer_phone;
        if (data.customer_email) document.querySelector('input[name="customer_email"]').value = data.customer_email;
        if (data.customer_address) document.getElementById('customer_address').value = data.customer_address;
        if (data.customer_city) document.getElementById('customer_city').value = data.customer_city;
        if (data.customer_zip) document.getElementById('customer_zip').value = data.customer_zip;
        if (data.customer_province) document.getElementById('customer_province').value = data.customer_province;
        if (data.country) document.getElementById('customer_country').value = data.country;
        
        // Compila il prodotto se rilevato - matching flessibile
        if (data.product_model) {
          const productSelect = document.getElementById('productSelect');
          const customInput = document.getElementById('customProduct');
          let found = false;
          
          // Normalizza il modello rilevato dall'AI
          const aiModel = data.product_model.toLowerCase().trim();
          
          // Cerca corrispondenza esatta prima
          for (let i = 0; i < productSelect.options.length; i++) {
            const optionValue = productSelect.options[i].value.toLowerCase();
            const optionText = productSelect.options[i].text.toLowerCase();
            
            // Match esatto
            if (productSelect.options[i].value === data.product_model) {
              productSelect.selectedIndex = i;
              found = true;
              customInput.style.display = 'none';
              if (productSelect.options[i].dataset.price) {
                document.getElementById('priceInput').value = productSelect.options[i].dataset.price;
              }
              break;
            }
          }
          
          // Se non trovato, cerca match parziale
          if (!found) {
            for (let i = 0; i < productSelect.options.length; i++) {
              const optionValue = productSelect.options[i].value.toLowerCase();
              const optionText = productSelect.options[i].text.toLowerCase();
              
              // Controlla se contiene "carbonio" o "alluminio"
              const isCarbonio = aiModel.includes('carbonio') || aiModel.includes('carbon');
              const isAlluminio = aiModel.includes('alluminio') || aiModel.includes('aluminium') || aiModel.includes('aluminum');
              
              const optionIsCarbonio = optionValue.includes('carbonio') || optionText.includes('carbonio');
              const optionIsAlluminio = optionValue.includes('alluminio') || optionText.includes('alluminio');
              
              if ((isCarbonio && optionIsCarbonio) || (isAlluminio && optionIsAlluminio)) {
                productSelect.selectedIndex = i;
                found = true;
                customInput.style.display = 'none';
                if (productSelect.options[i].dataset.price) {
                  document.getElementById('priceInput').value = productSelect.options[i].dataset.price;
                }
                break;
              }
            }
          }
          
          if (!found) {
            productSelect.value = 'custom';
            customInput.style.display = 'block';
            customInput.value = data.product_model;
          }
        }
        
        // Compila quantità
        if (data.quantity) {
          document.querySelector('input[name="quantity"]').value = data.quantity;
        }
        
        // Compila prezzo
        if (data.price_total) {
          document.getElementById('priceInput').value = data.price_total;
        }
        
        // Compila fonte
        if (data.source) {
          document.getElementById('sourceSelect').value = data.source;
          toggleSubitoSection();
        }
        
        // Compila note
        if (data.notes) {
          document.querySelector('textarea[name="notes"]').value = data.notes;
        }

        // Compila data vendita
        if (data.sale_date) {
          document.querySelector('input[name="sale_date"]').value = data.sale_date;
        }

        // Compila tracking code
        if (data.tracking_code) {
          document.querySelector('input[name="tracking_code"]').value = data.tracking_code;
        }

        // Compila urgente
        if (data.is_urgent) {
          document.getElementById('isUrgent').checked = true;
        }

        // Se c'è il CAP italiano, cerca comunque il comune (fallback)
        if (data.customer_zip && (data.country === 'Italia' || !data.country)) {
          lookupComune();
        }
        
        // Aggiorna lo stato dei campi indirizzo in base ai dati ricevuti
        if (!data.customer_address) {
          document.getElementById('includeAddress').checked = false;
          toggleAddressField('customer_address');
        }
        if (!data.customer_zip) {
          document.getElementById('includeCap').checked = false;
          toggleAddressField('customer_zip');
        }
        if (!data.customer_city) {
          document.getElementById('includeCity').checked = false;
          toggleAddressField('customer_city');
        }
        if (!data.customer_province) {
          document.getElementById('includeProvince').checked = false;
          toggleAddressField('customer_province');
        }

        const msg = data.confidence === 'high' 
          ? 'Dati estratti con alta confidenza!' 
          : data.confidence === 'medium'
            ? 'Dati estratti con media confidenza. Verifica prima di salvare.'
            : 'Dati estratti con bassa confidenza. Verifica attentamente prima di salvare.';
        showToast(msg, data.confidence === 'high' ? 'success' : 'warning');

      } catch (err) {
        console.error(err);
        showToast('Errore di connessione', 'error');
      } finally {
        btn.innerHTML = originalText;
        btn.disabled = false;
      }
    }

    // Lookup comune by CAP
    async function lookupComune() {
      const cap = document.getElementById('customer_zip').value.trim();
      if (!cap || cap.length !== 5) return;
      
      try {
        const res = await fetch(`/api/comuni/${cap}`);
        const data = await res.json();
        if (data.comune) {
          document.getElementById('customer_city').value = data.comune.nome;
          document.getElementById('customer_province').value = data.comune.provincia;
        }
      } catch (err) {
        console.error('Errore lookup comune:', err);
      }
    }

    // Verifica indirizzo con Google Maps
    async function verifyAddress() {
      // Raccogli TUTTI i campi dell'indirizzo
      const address = document.getElementById('customer_address').value.trim();
      const city = document.getElementById('customer_city').value.trim();
      const zip = document.getElementById('customer_zip').value.trim();
      const province = document.getElementById('customer_province').value.trim();
      const country = document.getElementById('customer_country').value;
      
      // Costruisci l'indirizzo completo per la ricerca
      let fullAddress = '';
      if (address) fullAddress += address;
      if (city) fullAddress += (fullAddress ? ', ' : '') + city;
      if (zip) fullAddress += (fullAddress ? ' ' : '') + zip;
      if (province) fullAddress += (fullAddress ? ' ' : '') + `(${province})`;
      if (country) fullAddress += (fullAddress ? ', ' : '') + country;
      
      if (!fullAddress) {
        showToast('Inserisci almeno un campo indirizzo', 'error');
        return;
      }
      
      const btn = event.target.closest('button');
      const originalHTML = btn.innerHTML;
      btn.innerHTML = '<span class="loading-spinner"></span>';
      btn.disabled = true;
      
      try {
        const res = await fetch(`/api/geocode?address=${encodeURIComponent(address)}&city=${encodeURIComponent(city)}&zip=${encodeURIComponent(zip)}&province=${encodeURIComponent(province)}&country=${encodeURIComponent(country)}`);
        const data = await res.json();
        
        const resultDiv = document.getElementById('geocodeResult');
        
        if (data.success) {
          // Compila i campi con i dati verificati
          if (data.result.route) {
            const streetNumber = data.result.street_number || '';
            document.getElementById('customer_address').value = `${data.result.route} ${streetNumber}`.trim();
          }
          if (data.result.postal_code) {
            document.getElementById('customer_zip').value = data.result.postal_code;
          }
          if (data.result.locality) {
            document.getElementById('customer_city').value = data.result.locality;
          }
          if (data.result.administrative_area_level_2) {
            document.getElementById('customer_province').value = data.result.administrative_area_level_2;
          }
          if (data.result.country) {
            // Cerca il codice ISO del paese
            const countryCode = getCountryCode(data.result.country);
            document.getElementById('customer_country').value = `${data.result.country} (${countryCode})`;
          }
          
          resultDiv.textContent = `✓ Indirizzo verificato: ${data.result.formatted_address}`;
          resultDiv.style.color = 'var(--success)';
          showToast('Indirizzo verificato con successo!', 'success');
        } else {
          resultDiv.textContent = '⚠ Indirizzo non trovato. Verifica i dati inseriti.';
          resultDiv.style.color = 'var(--warning)';
          showToast('Indirizzo non trovato', 'warning');
        }
        resultDiv.style.display = 'block';
      } catch (err) {
        console.error('Geocoding error:', err);
        showToast('Errore durante la verifica', 'error');
      } finally {
        btn.innerHTML = originalHTML;
        btn.disabled = false;
      }
    }
    
    // Helper per ottenere il codice paese
    function getCountryCode(countryName) {
      const countryMap = {
        'Italia': 'IT', 'Italy': 'IT',
        'Svizzera': 'CH', 'Switzerland': 'CH', 'Schweiz': 'CH',
        'San Marino': 'SM',
        'Città del Vaticano': 'VA', 'Vatican City': 'VA',
        'Francia': 'FR', 'France': 'FR',
        'Germania': 'DE', 'Germany': 'DE', 'Deutschland': 'DE',
        'Austria': 'AT', 'Österreich': 'AT',
        'Spagna': 'ES', 'Spain': 'ES', 'España': 'ES',
        'Regno Unito': 'GB', 'United Kingdom': 'GB', 'UK': 'GB',
        'Belgio': 'BE', 'Belgium': 'BE', 'Belgique': 'BE',
        'Paesi Bassi': 'NL', 'Netherlands': 'NL', 'Nederland': 'NL',
        'Lussemburgo': 'LU', 'Luxembourg': 'LU',
        'Portogallo': 'PT', 'Portugal': 'PT',
        'Polonia': 'PL', 'Poland': 'PL', 'Polska': 'PL',
        'Romania': 'RO', 'Romania': 'RO', 'România': 'RO',
        'Bulgaria': 'BG', 'България': 'BG',
        'Grecia': 'GR', 'Greece': 'GR', 'Ελλάδα': 'GR',
        'Ungheria': 'HU', 'Hungary': 'HU', 'Magyarország': 'HU',
        'Repubblica Ceca': 'CZ', 'Czech Republic': 'CZ', 'Česká republika': 'CZ',
        'Slovacchia': 'SK', 'Slovakia': 'SK', 'Slovensko': 'SK',
        'Danimarca': 'DK', 'Denmark': 'DK', 'Danmark': 'DK',
        'Svezia': 'SE', 'Sweden': 'SE', 'Sverige': 'SE',
        'Norvegia': 'NO', 'Norway': 'NO', 'Norge': 'NO',
        'Finlandia': 'FI', 'Finland': 'FI', 'Suomi': 'FI',
        'Irlanda': 'IE', 'Ireland': 'IE', 'Éire': 'IE',
        'Stati Uniti': 'US', 'United States': 'US', 'USA': 'US',
        'Canada': 'CA',
        'Australia': 'AU',
        'Russia': 'RU', 'Россия': 'RU',
        'Ucraina': 'UA', 'Ukraine': 'UA', 'Україна': 'UA'
      };
      return countryMap[countryName] || 'XX';
    }

    <% if (mode === 'edit') { %>
    // Update display number
    async function updateDisplayNumber() {
      const displayNumber = document.getElementById('displayNumber').value.trim();
      if (!displayNumber) {
        showToast('Inserisci un numero valido', 'error');
        return;
      }
      
      try {
        const res = await fetch(`/api/orders/<%= order.id %>/display-number`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ display_number: displayNumber })
        });
        
        if (res.ok) {
          showToast('Numero ordine aggiornato!', 'success');
        } else {
          const data = await res.json();
          showToast(data.error || 'Errore', 'error');
        }
      } catch (err) {
        showToast('Errore di connessione', 'error');
      }
    }
    <% } %>

    // Form submit
    document.getElementById('orderForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(e.target);
      const data = Object.fromEntries(formData);
      
      // Handle custom product
      if (data.product_model === 'custom') {
        data.product_model = document.getElementById('customProduct').value;
      }
      
      data.is_urgent = data.is_urgent === 'true';
      data.is_subito_pickup = data.is_subito_pickup === 'true';
      data.subito_address_optional = document.getElementById('isSubitoPickup').checked;
      data.quantity = parseInt(data.quantity);
      data.price_total = parseFloat(data.price_total);
      
      // If subito pickup, clear address fields
      if (data.is_subito_pickup) {
        data.customer_address = null;
        data.customer_city = null;
        data.customer_zip = null;
        data.customer_province = null;
      }

      try {
        const url = '<%= mode === "create" ? "/api/orders" : "/api/orders/" + order.id %>';
        const method = '<%= mode === "create" ? "POST" : "PUT" %>';
        
        const res = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        if (res.ok) {
          showToast('<%= mode === "create" ? "Ordine creato!" : "Modifiche salvate!" %>', 'success');
          setTimeout(() => window.location.href = '/', 1000);
        } else {
          showToast('Errore nel salvataggio', 'error');
        }
      } catch (err) {
        showToast('Errore di connessione', 'error');
      }
    });

    <% if (mode === 'edit') { %>
    // Delete order
    async function deleteOrder(id) {
      if (!confirm('Sei sicuro di voler eliminare questo ordine?')) return;
      
      try {
        const res = await fetch(`/api/orders/${id}`, { method: 'DELETE' });
        if (res.ok) {
          showToast('Ordine eliminato', 'success');
          setTimeout(() => window.location.href = '/', 1000);
        }
      } catch (err) {
        showToast('Errore', 'error');
      }
    }
    <% } %>

    // Toast
    function showToast(msg, type) {
      const container = document.getElementById('toastContainer');
      const toast = document.createElement('div');
      toast.className = `toast toast-${type}`;
      toast.textContent = msg;
      container.appendChild(toast);
      setTimeout(() => toast.remove(), 3000);
    }
  </script>
</body>
</html>
