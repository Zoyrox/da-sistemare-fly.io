<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Coda Etichette - MotoStaffa Office</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" type="image/svg+xml" href="/img/logo.svg">
</head>
<body>
  <div class="app-container">
    <!-- Sidebar -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-header">
        <div class="logo">
          <div class="logo-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          </div>
          <div class="logo-text">
            <h1>MotoStaffa</h1>
            <span>Office</span>
          </div>
        </div>
      </div>

      <nav class="sidebar-nav">
        <a href="/" class="nav-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
          Dashboard
        </a>
        <a href="/orders/new" class="nav-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12h8"/><path d="M12 8v8"/></svg>
          Nuovo Ordine
        </a>
        <a href="/search" class="nav-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          Ricerca Avanzata
        </a>
        <a href="/labels/queue" class="nav-item active">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect width="12" height="8" x="6" y="14"/></svg>
          Coda Etichette
          <% if (orders.length > 0) { %>
            <span class="nav-badge"><%= orders.length %></span>
          <% } %>
        </a>
        <a href="/stats" class="nav-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
          Statistiche
        </a>
        <div class="sidebar-divider"></div>
        <a href="/api/export" class="nav-item" download>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Esporta Dati
        </a>
      </nav>

      <div class="sidebar-footer">
        <div class="user-info">
          <div class="user-avatar">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <div class="user-details">
            <div class="name"><%= user.username %></div>
            <div class="role">Amministratore</div>
          </div>
        </div>
        <form action="/logout" method="POST">
          <button type="submit" class="btn btn-secondary" style="width: 100%;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Logout
          </button>
        </form>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
      <header class="header">
        <div class="header-left">
          <button class="menu-toggle" id="menuToggle">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
          </button>
          <div class="page-title">
            <h2>Coda Etichette</h2>
            <p>Gestisci le etichette da stampare</p>
          </div>
        </div>
        <div style="display: flex; gap: 10px;">
          <% if (orders.length > 0) { %>
            <button class="btn btn-danger" onclick="clearQueue()">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
              Svuota
            </button>
            <a href="/labels/print" target="_blank" class="btn btn-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect width="12" height="8" x="6" y="14"/></svg>
              Stampa Tutte (<%= orders.length %>)
            </a>
          <% } %>
        </div>
      </header>

      <div class="content">
        <% if (orders.length === 0) { %>
          <div class="empty-state" style="padding: 60px 20px;">
            <div class="empty-state-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect width="12" height="8" x="6" y="14"/></svg>
            </div>
            <h3>Nessuna etichetta in coda</h3>
            <p style="margin-bottom: 20px;">Aggiungi ordini alla coda dalla dashboard cliccando sull'icona etichetta</p>
            <a href="/" class="btn btn-primary">Vai alla Dashboard</a>
          </div>
        <% } else { %>
          <div class="card">
            <div class="card-header">
              <h3 class="card-title">Ordini in coda</h3>
              <span style="font-size: 13px; color: var(--text-muted);"><%= orders.length %> etichette</span>
            </div>
            <div class="table-container">
              <table class="table">
                <thead>
                  <tr>
                    <th>N° Ordine</th>
                    <th>Destinatario</th>
                    <th>Indirizzo</th>
                    <th>Città</th>
                    <th>Paese</th>
                    <th>Azioni</th>
                  </tr>
                </thead>
                <tbody>
                  <% orders.forEach(order => { %>
                    <tr>
                      <td>
                        <span class="order-number"><%= order.order_display_number || '#' + order.id %></span>
                      </td>
                      <td>
                        <div style="font-weight: 500;"><%= order.customer_name %></div>
                      </td>
                      <td>
                        <div style="font-size: 13px;"><%= order.customer_address || 'N/D' %></div>
                      </td>
                      <td>
                        <div style="font-size: 13px;">
                          <%= order.customer_zip || '' %> <%= order.customer_city || 'N/D' %>
                          <%= order.customer_province ? '(' + order.customer_province + ')' : '' %>
                        </div>
                      </td>
                      <td>
                        <span class="country-badge <%= order.customer_country && order.customer_country !== 'Italia' ? 'international' : '' %>">
                          <%= order.customer_country || 'Italia' %>
                        </span>
                      </td>
                      <td>
                        <div class="action-buttons">
                          <a href="/orders/<%= order.id %>/label" target="_blank" class="btn btn-sm btn-secondary btn-icon" title="Stampa singola">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect width="12" height="8" x="6" y="14"/></svg>
                          </a>
                          <button class="btn btn-sm btn-danger btn-icon" onclick="removeFromQueue('<%= order.id %>')" title="Rimuovi">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                          </button>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Print Preview -->
          <div class="card" style="margin-top: 24px;">
            <div class="card-header">
              <h3 class="card-title">Anteprima Stampa</h3>
            </div>
            <div class="card-body">
              <div class="label-preview-grid">
                <% orders.forEach(order => { %>
                  <div class="label-preview-item">
                    <div class="label-preview-type">DESTINATARIO</div>
                    <div class="label-preview-name"><%= order.customer_name %></div>
                    <div class="label-preview-address"><%= order.customer_address %></div>
                    <div class="label-preview-city">
                      <%= order.customer_zip %> <%= order.customer_city %>
                      <%= order.customer_province ? '(' + order.customer_province + ')' : '' %>
                    </div>
                    <div class="label-preview-country"><%= order.customer_country || 'Italia' %></div>
                  </div>
                <% }) %>
              </div>
            </div>
          </div>
        <% } %>
      </div>
    </main>
  </div>

  <div class="toast-container" id="toastContainer"></div>

  <script>
    // Mobile menu
    document.getElementById('menuToggle').addEventListener('click', () => {
      document.getElementById('sidebar').classList.toggle('open');
    });

    async function removeFromQueue(orderId) {
      if (!confirm('Rimuovere questo ordine dalla coda?')) return;
      
      try {
        const res = await fetch(`/api/label-queue/${orderId}`, { method: 'DELETE' });
        if (res.ok) {
          showToast('Rimosso dalla coda', 'success');
          setTimeout(() => location.reload(), 500);
        }
      } catch (err) {
        showToast('Errore', 'error');
      }
    }

    async function clearQueue() {
      if (!confirm('Svuotare tutta la coda etichette?')) return;
      
      try {
        const res = await fetch('/api/label-queue', { method: 'DELETE' });
        if (res.ok) {
          showToast('Coda svuotata', 'success');
          setTimeout(() => location.reload(), 500);
        }
      } catch (err) {
        showToast('Errore', 'error');
      }
    }

    // Toast
    function showToast(msg, type) {
      const container = document.getElementById('toastContainer');
      const toast = document.createElement('div');
      toast.className = `toast toast-${type}`;
      toast.textContent = msg;
      container.appendChild(toast);
      setTimeout(() => toast.remove(), 3000);
    }
  </script>
</body>
</html>
