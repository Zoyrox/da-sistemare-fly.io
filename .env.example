# MotoStaffa Office - Configurazione Esempio
# Copia questo file in .env e modifica i valori

# Ambiente: development | production
NODE_ENV=development

# Porta del server (Render usa la porta dalla variabile d'ambiente)
PORT=3000

# Chiave segreta per le sessioni (usa una stringa casuale lunga in produzione)
SESSION_SECRET=your-super-secret-key-change-this

# Credenziali admin (username in chiaro, password hashata con bcrypt)
ADMIN_USERNAME=admin
# Password di default: "motostaffa2024" - genera il tuo hash con bcrypt
ADMIN_PASSWORD_HASH=$2a$10$92IXUNpkjO0rOQ5byMi.Ye4oKoEa3Ro9llC/.og/at2.uheWG/igi

# Percorso disco persistente Render (lasciare così per Render.com)
# In locale, il database verrà salvato in ./data/
RENDER_DISK_PATH=/data
